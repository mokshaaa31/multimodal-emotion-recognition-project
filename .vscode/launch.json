{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Streamlit App",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/app.py",
                "--server.port=8501"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Test Video Model",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test_models.py",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}
